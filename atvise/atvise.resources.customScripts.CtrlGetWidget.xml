	<UAVariable NodeId="ns=1;s=SYSTEM.LIBRARY.ATVISE.RESOURCES/customScripts/CtrlGetWidget" BrowseName="1:CtrlGetWidget" DataType="XmlElement" AccessLevel="103" UserAccessLevel="103" Historizing="true">
