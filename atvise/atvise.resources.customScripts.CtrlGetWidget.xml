		<Description Locale="en">CtrlGetWidget</Description>
		<References>
			<Reference ReferenceType="HasComponent" IsForward="false">ns=1;s=SYSTEM.LIBRARY.ATVISE.RESOURCES/customScripts</Reference>
			<Reference ReferenceType="HasTypeDefinition">ns=1;s=VariableTypes.ATVISE.ScriptCode</Reference>
		</References>
		<Value>
			<uax:XmlElement><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<script>
  <metadata>
    <priority>0</priority>
    <owner>root</owner>
    <runcontext>caller</runcontext>
  </metadata>
  <parameter name="request" type="http.request" trigger="false" relative="false" value=""/>
  <parameter name="response" type="http.response" trigger="false" relative="false" value=""/>
  <code><![CDATA[// response.write(JSON.stringify(request.getValues, null, 2))
var widget = request.getvalues['widget']

var node = Ua.findNode(widget).result.value
//console.log(node)
// No access, return noAccess display
if(!node){
	var widget = 'SYSTEM.LIBRARY.ATVISE.OBJECTDISPLAYS._jmh.system.noAccess'
	var node = Ua.findNode(widget).result.value
	var xmlDoc = new XMLDoc(node, "string");
	return {html:xmlDoc.root.toString(), script:''}
}

var xmlDoc = new XMLDoc(node, "string");
var x = xmlDoc.root
var code = ''

// Replace all system.globals with values
var parameter = xmlDoc.root.first('metadata').first('parameter')
for(; parameter; parameter = parameter.next('parameter')){
//	console.log(parameter)	
	var attr = parameter.attribute('defaultvalue')
	if(attr.includes('SYSTEM.GLOBALS')){
		var uanode = Ua.findNode(attr)
		if(uanode.error === 0){
			parameter.setattribute('defaultvalue', uanode.result.value + '')
		} else {
			console.log('could not find global parameter:' + attr + ',for component: ' + widget )	
		} 

	}	
}

function getScript(el){
	var nodeid = el.attribute('href')
	var scriptText = Ua.findNode(nodeid)
	var test = new XMLDoc(scriptText.result.value, "string")
	return test.root.first('code').first(XMLDoc.CDATA_SECTION_NODE).content
}
var script = ''

for(x = x.first('script'); x; x = x.next('script')){
	if(x.attribute('href')) {
		// return getScript(x)
		//code += getScript(x)			
		script += '\n' + getScript(x)
	}else{
		
		var item = x.first(XMLDoc.CDATA_SECTION_NODE)
		if (item) {
			script += '\n' + item.content
		} else { 
			x.setcontent('')
			// x.setcontent(code)
		}
		
	}	
}
response.setHeader("Content-Type", "application/json");

response.write(JSON.stringify({html:xmlDoc.root.toString(), script:script}))
//return {html:xmlDoc.root.toString(), script:script}

 ]]]]><![CDATA[></code>
</script>
